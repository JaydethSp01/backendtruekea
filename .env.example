# Copia a .env y ajusta valores. No subas .env al repositorio.

# App
NODE_ENV=development
PORT=3000

# Detrás de nginx / balanceador (IPs reales en logs)
TRUST_PROXY=

# Orígenes CORS permitidos, separados por coma. Vacío o * = reflejar / abierto (desarrollo).
# Ejemplo producción: https://tu-dominio.com,https://app.tu-dominio.com
CORS_ORIGIN=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=truekea

# En desarrollo, por defecto TypeORM sincroniza el esquema (auto).
# En producción (NODE_ENV=production) el valor por defecto es false.
# Primera instalación en prod: migraciones o DB_SYNCHRONIZE=true una sola vez (documentado en README).
DB_SYNCHRONIZE=

# JWT (en producción JWT_SECRET y JWT_REFRESH_SECRET son obligatorios y no pueden ser de ejemplo)
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Azure Blob (opcional; sin esto las subidas de imagen pueden fallar)
AZURE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=img-truekea1

# Seed opcional (npm run seed:test-user)
SEED_TEST_EMAIL=test@example.com
SEED_TEST_PASSWORD=password123
SEED_TEST_NAME=Usuario de Prueba
